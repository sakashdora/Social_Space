datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String              @id @default(uuid())
  handle       String              @unique
  recoveryHash String
  isBanned     Boolean             @default(false)
  avatarUrl    String?
  lastActiveAt DateTime            @default(now())
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  posts        Post[]
  comments     Comment[]
  reactions    Reaction[]
  threads      ThreadParticipant[]
  messages     Message[]
}

model Post {
  id                String          @id @default(uuid())
  userId            String?
  user              User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  content           String
  category          String
  aiLabels          String?         // Storing JSON string of AI safety scores
  mediaUrl          String?
  sentimentAnalysis String?         // Storing JSON string of sentiment score
  isDeleted         Boolean         @default(false)
  
  // For sharing other posts or chat messages
  sharedPostId      String?
  sharedPost        Post?           @relation("SharedPosts", fields: [sharedPostId], references: [id], onDelete: SetNull)
  shares            Post[]          @relation("SharedPosts")
  
  createdAt         DateTime        @default(now())
  comments          Comment[]
  reactions         Reaction[]
  moderationLogs    ModerationLog[]
}

model Comment {
  id              String          @id @default(uuid())
  postId          String
  post            Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentCommentId String?
  parentComment   Comment?        @relation("ThreadReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         Comment[]       @relation("ThreadReplies")
  content         String
  isDeleted       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  reactions       Reaction[]
  moderationLogs  ModerationLog[]
}

model Reaction {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId       String?
  post         Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId    String?
  comment      Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reactionType String
  createdAt    DateTime @default(now())

  @@unique([userId, postId, commentId, reactionType])
}

model ModerationLog {
  id                      String   @id @default(uuid())
  targetPostId            String?
  targetPost              Post?    @relation(fields: [targetPostId], references: [id], onDelete: Cascade)
  targetCommentId         String?
  targetComment           Comment? @relation(fields: [targetCommentId], references: [id], onDelete: Cascade)
  adminUserId             String?
  actionTaken             String
  reason                  String
  aiFlags                 String?  // Storing JSON string of AI flags
  originalContentSnapshot String
  createdAt               DateTime @default(now())
}

model Thread {
  id                 String              @id @default(uuid())
  deleteAfterSeconds Int                 @default(604800) // default 7 days = 604800
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  participants       ThreadParticipant[]
  messages           Message[]
}

model ThreadParticipant {
  id        String   @id @default(uuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([threadId, userId])
}

model Message {
  id        String   @id @default(uuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  mediaUrl  String?
  createdAt DateTime @default(now())
  expiresAt DateTime
}
